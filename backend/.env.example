# Database
ConnectionStrings__DefaultConnection=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=your-db;User ID=your-user;Password=your-password;

# JWT Auth
Auth__JwtKey=your-jwt-secret-key
Auth__JwtIssuer=Resilio
Auth__JwtAudience=ResilioClient

# OTP
Otp__HmacSecret=your-otp-secret

# Token Hashing
TokenHashing__HmacSecret=your-token-secret